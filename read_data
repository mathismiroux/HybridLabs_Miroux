def extract_modes(f06_text):
    """
    Extracts mode shapes (T1,T2,T3,R1,R2,R3), eigenvalues, and frequencies.
    """
    mode_pattern = r"R E A L   E I G E N V E C T O R\s+NO\.\s+(\d+).*?FREQUENCY\s*=\s*([\d\.E\+\-]+).*?(?=(?:R E A L   E I G E NVEC|$))"
    matches = re.findall(mode_pattern, f06_text, re.DOTALL)
    
    mode_data = []
    for mode_no, freq, *rest in re.findall(r"R E A L   E I G E N V E C T O R\s+NO\.\s+(\d+).*?EIGENVALUE\s*=\s*([\d\.E\+\-]+).*?FREQUENCY\s*=\s*([\d\.E\+\-]+)", f06_text, re.DOTALL):
        block_pattern = rf"R E A L   E I G E N V E C T O R\s+NO\.\s+{mode_no}.*?(?=(?:R E A L   E I G E NVEC|$))"
        block_match = re.search(block_pattern, f06_text, re.DOTALL)
        if not block_match:
            continue
        block = block_match.group(0)

        # Extract modeshape table lines
        lines = [l.strip() for l in block.splitlines() if re.match(r'^\d+', l.strip())]
        cols = ['GRID', 'T1', 'T2', 'T3', 'R1', 'R2', 'R3']
        rows = []
        for l in lines:
            parts = re.split(r'\s+', l)
            if len(parts) >= 7:
                rows.append(parts[:7])
        df = pd.DataFrame(rows, columns=cols).astype(float)
        df['Mode'] = int(mode_no)
        df['Eigenvalue'] = float(freq)
        df['Frequency (Hz)'] = float(freq)
        mode_data.append(df)

    return mode_data


