def plot_modeshape(mode_df, mode_number):
    freq = mode_df['Frequency (Hz)'].iloc[0]
    plt.figure(figsize=(8, 5))
    plt.plot(mode_df['GRID'], mode_df['T1'], label='T1')
    plt.plot(mode_df['GRID'], mode_df['T2'], label='T2')
    plt.plot(mode_df['GRID'], mode_df['T3'], label='T3')
    plt.title(f"Mode {mode_number} — Frequency = {freq:.2f} Hz")
    plt.xlabel("GRID ID")
    plt.ylabel("Displacement")
    plt.legend()
    plt.grid(True)
    plt.show()


