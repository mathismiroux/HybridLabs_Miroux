def read_f06(filepath):
    """
    Reads an F06 file, removes page headers/footers, unwanted lines, 
    repeated 3-line blocks starting with '0', and writes cleaned text to a new file.
    """
    with open(filepath, 'r', errors='ignore') as f:
        lines = f.readlines()

    # Find the line where the summary starts
    i = 0
    while i < len(lines) and 'E L E M E N T   P R O P E R T Y   S U M M A R Y' not in lines[i]:
        i += 1

    print('found summary at line', i)
    lines = lines[i:]  # Start processing from the summary section

    cleaned_lines = []
    previous_block = None
    idx = 0
    while idx < len(lines):
        # Remove form feed characters (page breaks)
        line = lines[idx].replace('\x0c', '')
        stripped = line.rstrip('\n')

        # 🛑 If 'END-OF-DATA' is found, stop processing completely
        if 'END-OF-DATA' in stripped:
            print(f"Found END-OF-DATA at line {i + idx}. Truncating here.")
            break

        # # Remove all whitespace (spaces, tabs, etc.) and convert to uppercase
        # normalized = ''.join(stripped.split()).upper()

        # # Check if line starts with 'ELEMENTTYPE='
        # if normalized.startswith('ELEMENTTYPE='):
        #     idx += 1
        #     print(f"Skipping ELEMENT TYPE line at {i + idx}")
        #     continue

        # Skip empty or whitespace-only lines
        if not stripped.strip():
            idx += 1
            continue
        

        # Skip lines starting with '*'
        if stripped.lstrip().startswith('*'):
            idx += 1
            continue
        

        # Skip page numbers
        if re.match(r'^\s*PAGE\s+\d+', stripped, re.IGNORECASE):
            idx += 1
            continue

        # Skip headers/footers or other unwanted keywords
        if ('MSC Nastran' in stripped or
            'PAGE' in stripped or
            'OCTOBER' in stripped or
            'NASTRAN' in stripped):
            idx += 1
            continue

        # 🧠 Detect and skip repeated 3-line blocks starting with '0'
        if stripped.lstrip().startswith('0'):
            # Get this 3-line block (or fewer if at file end)
            current_block = [lines[idx + j].replace('\x0c', '').rstrip('\n') 
                             for j in range(5) if idx + j < len(lines)]

            if current_block == previous_block:
                # Skip the repeated block
                idx += len(current_block)
                continue
            else:
                # New block: memorize it
                previous_block = current_block
                cleaned_lines.extend(current_block)
                idx += len(current_block)
                continue

        # If nothing skipped, keep the line
        cleaned_lines.append(stripped)
        idx += 1

    cleaned_text = '\n'.join(cleaned_lines)

    # Build output file path
    base, ext = os.path.splitext(filepath)
    output_path = f"{base}_cleaned{ext}"

    # Write cleaned content to the new file
    with open(output_path, 'w', encoding='utf-8') as f:
        f.write(cleaned_text)

    print(f"✅ Cleaned file saved as: {output_path}")
    return cleaned_text



