from io import StringIO



def parse_element_summary(text):
    element_dfs = {}

    # Split the text into element types
    sections = re.split(r'ELEMENT TYPE\s*=\s*(\w+)', text, flags=re.IGNORECASE)
    for i in range(1, len(sections)-1, 2):
        element_type = sections[i].strip()
        section_text = sections[i+1]

        if element_type.upper() == "CONM1":
            # Split section into lines
            lines = section_text.strip().splitlines()
            filtered_lines = []

            for line in lines:
                # Stop if we hit totals/subtotals (-----)
                if re.search(r'-{3,}', line):
                    break
                # Skip lines that contain only a single zero
                if re.match(r'^\s*0\s*$', line):
                    continue
                # Keep only numeric rows (ignore headers and blank lines)
                if re.match(r'\s*\d+', line):
                    filtered_lines.append(line.strip())

            # Split each line by whitespace
            data = [re.split(r'\s+', l) for l in filtered_lines]

            # Define expected columns
            columns = ["ELEM ID", "PROP ID", "MATL ID", "STRUCT.MASS", "NON-STR.MASS", "TOTAL MASS", "TM*WTMASS"]

            if data:
                df_block = pd.DataFrame(data, columns=columns)
                for col in columns:
                    df_block[col] = pd.to_numeric(df_block[col], errors='coerce')

                # ✅ Accumulate rather than overwrite
                if "CONM1" in element_dfs:
                    element_dfs["CONM1"] = pd.concat([element_dfs["CONM1"], df_block], ignore_index=True)
                else:
                    element_dfs["CONM1"] = df_block

        elif element_type.upper() == "BEAM":
            # --- Locate the header line
            header_match = re.search(r'ELEM ID.*', section_text)
            if not header_match:
                continue
            start_idx = section_text.find(header_match.group())
            block_text = section_text[start_idx:]
            header_line = header_match.group().strip()

            # --- Remove any lines containing '-----'
            filtered_lines = []
            for line in block_text.splitlines():
                if re.search(r'-{3,}', line):   # 3 or more dashes
                    break  # stop reading at the first totals/subtotals line
                                # skip lines with only "0"
                if re.match(r'^\s*0\s*$', line):
                    break
                filtered_lines.append(line)
            block_text = "\n".join(filtered_lines)

            # --- Extract column names dynamically
            columns = ["ELEM ID", "PROP ID", "MATL ID", "LENGTH", "AREA", "VOLUME", "STRUCT.MASS", "NON-STR.MASS", "TOTAL MASS", "TM*WTMASS"]

            # --- Parse the filtered text
            df = pd.read_fwf(
                StringIO(block_text),
                names=columns,
                widths=None,
                skiprows=1,
                skip_blank_lines=True
            )
            element_dfs[element_type] = df

    return element_dfs


def parse_eigenvectors(text):
    # Regex to capture eigenvalue, cycles, and mode
    header_pattern = re.compile(
        r'\s*EIGENVALUE\s*=\s*([-\d.E+]+)\s*\n\s*CYCLES\s*=\s*([-\d.E+]+).*?(\d+)',
        flags=re.IGNORECASE | re.DOTALL
    )

    # Split the text at each header
    sections = re.split(header_pattern, text)

    # Dictionary to store dataframes keyed by mode number
    eigenvector_dict = {}

    # Iterate in steps of 4 starting from index 1
    for i in range(1, len(sections), 4):
        eigval = float(sections[i])
        cycles = float(sections[i+1])
        mode_no = int(sections[i+2])
        table_text = sections[i+3]

        print(f"Parsing Eigenvector Mode No: {mode_no}, Eigenvalue: {eigval}, Cycles: {cycles}")

        # Collect table lines
        table_lines = []
        for line in table_text.splitlines():
            if re.match(r'^\s*$', line):
                continue
            if line.strip().startswith("SUBCASE"):
                break
            table_lines.append(line)

        if table_lines:
            table_data = "\n".join(table_lines)
            columns = ["POINT ID", "TYPE", "T1", "T2", "T3", "R1", "R2", "R3"]
            df_eig = pd.read_fwf(StringIO(table_data), names=columns, skiprows=1, skip_blank_lines=True)
            df_eig["EIGENVALUE"] = eigval
            df_eig["CYCLES"] = cycles
            df_eig["MODE_NO"] = mode_no

            # Store dataframe in dictionary keyed by mode number
            eigenvector_dict[mode_no] = df_eig

    return eigenvector_dict if eigenvector_dict else None
