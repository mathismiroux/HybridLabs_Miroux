def extract_element_summary(f06_text, element_type):
    """
    Extracts element property summary tables for a given element type (BEAM or CONM1).
    Handles multi-page tables and split lines.
    """
    # Find the block for the element type
    pattern = rf"ELEMENT TYPE = {element_type}[\s\S]+?(?=(?:ELEMENT TYPE|TOTAL MASS|$))"
    match = re.search(pattern, f06_text, re.IGNORECASE)
    if not match:
        return pd.DataFrame()

    data_block = match.group(0)

    # Split into lines and find header line
    lines = [l.rstrip() for l in data_block.splitlines() if l.strip()]
    header_idx = None
    for i, l in enumerate(lines):
        if 'ELEM ID' in l:
            header_idx = i
            break
    if header_idx is None:
        return pd.DataFrame()

    # Use any whitespace for splitting
    headers = re.split(r'\s+', lines[header_idx].strip())
    data_lines = lines[header_idx+1:]

    # Collect rows, skipping subtotal and separator lines
    rows = []
    for l in data_lines:
        if l.strip().startswith('SUBTOTAL') or l.strip().startswith('='):
            continue
        row = re.split(r'\s+', l.strip())
        if len(row) == len(headers):
            rows.append(row)

    if not rows:
        return pd.DataFrame()

    df = pd.DataFrame(rows, columns=headers)
    return df
    
