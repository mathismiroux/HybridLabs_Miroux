/* Options File */
STEP;
HEADER;
FILE_DESCRIPTION(('''
User Options for importing/exporting files between MSC.Patran and MSC.Patran
'''));
FILE_NAME('express.opt','''Wednesday, 12 November 2025, 12:00:07
(Wednesday, 12 November 2025, 12:00:07 Greenwich)''',('''MSC.Patran'''),
('''Hexagon Manufacturing Intelligence, Inc.'''),
('''The Hexagon Manufacturing Intelligence, Inc., PATRAN Procedural Interface, 
Version 1.0'''));
FILE_SCHEMA('MSC_Express_NeutralFile_V1');
ENDSEC;
DATA;
#1 = FILE( .IMPORT., .STEP., .BINARY_REPRESENTATION. );
#2 = PREFERENCE( .GENERAL_AND_SIMPLE_TRIMMED_SURFACES., .NO_PREFERENCE., 
.B_REP_SOLIDS_W_PSOLID_CONVERT. );
#3 = GLOBAL_TRANSFORMATION( ( 3.93700790405273438E+01, 0.000000000000E+00, 
0.000000000000E+00, 0.000000000000E+00, 3.93700790405273438E+01, 
0.000000000000E+00, 0.000000000000E+00, 0.000000000000E+00, 
3.93700790405273438E+01, 0.000000000000E+00, 0.000000000000E+00, 
0.000000000000E+00 ) );
#4 = ENTITY_TYPE_LIST( .T., $ );
#5 = LAYER_LIST( .T., $ );
#6 = COLOR_LIST( .T., $ );
ENDSEC;
ENDSTEP;
